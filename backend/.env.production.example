# Production Environment Variables
# Copy this file and set actual values in Railway dashboard

# Server Configuration
NODE_ENV=production
PORT=3000
API_VERSION=v1

# Database Configuration (Provided by Railway PostgreSQL)
DATABASE_URL=${RAILWAY_POSTGRES_URL}
# Or manually set:
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT Configuration (MUST CHANGE THESE!)
JWT_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=CHANGE_THIS_TO_ANOTHER_STRONG_RANDOM_STRING
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS Configuration (Set your Vercel frontend URL)
CORS_ORIGIN=https://your-app.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Simulation
SIMULATION_INTERVAL_HOURS=1
TIME_SCALE=1.0
